############################################################
# 🟢 ১. AUTHENTICATION & USER APIs
############################################################

### User Registration
POST http://localhost:8080/api/auth/user/registar
Content-Type: application/json

{
  "username": "mehedi",
  "email": "mehedi@gmail.com",
  "password": "123",
  "role": "USER",
  "countryId": "BD"
}
> {% client.global.set("userId1", response.body.id); %}

### User Login
POST http://localhost:8080/api/auth/user/login
Content-Type: application/json

{
  "email": "mehedi@gmail.com",
  "password": "123"
}


############################################################
# 🔵 ২. DATA CREATION (POST APIs)
############################################################

### Add Destination
POST http://localhost:8080/api/destination/add
Content-Type: application/json

{
  "name": "Cox's Bazar",
  "region": "Chittagong",
  "description": "The longest natural sandy beach in the world.",
  "isAlive": true
}
> {% client.global.set("destinationId1", response.body.id); %}

### Add Hotel
POST http://localhost:8080/api/hotels/add
Content-Type: application/json

{
  "vendor": {
    "id": 1
  },
  "destinationId": {
    "id": 1
  },
  "hotelName": "Radisson Blu",
  "address": "Dhaka",
  "status": "ACTIVE",
  "descriptions": "Five star luxury hotel"
}

> {% client.global.set("hotelId1", response.body.id); %}

### Add Room
POST http://localhost:8080/api/rooms/add
Content-Type: application/json

{
  "hotel": {
    "id": 1
  },
  "roomTypeName": "Deluxe King",
  "amenities": "WiFi, AC, TV, Mini Bar",
  "pricePerNight": 5000.0,
  "availableQuantities": 10,
  "status": "AVAILABLE"
}
> {% client.global.set("roomId1", response.body.id); %}

### Add Transport
POST http://localhost:8080/api/transports/add
Content-Type: application/json

{
  "origin": {
    "id": 1
  },
  "destination": {
    "id": 1
  },
  "model": "Hino 1J (Non-AC)",
  "operatorName": "Hanif Enterprise",
  "estimatedCost": 850.0,
  "estimatedDuration": "12 hours",
  "frequency": "Daily"
}
> {% client.global.set("transportId1", response.body.id); %}

