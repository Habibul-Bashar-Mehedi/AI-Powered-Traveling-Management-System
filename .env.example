# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ============================================
# Application Configuration
# ============================================
APP_BASE_URL=http://localhost:8080
SERVER_PORT=8080

# ============================================
# Database Configuration
# ============================================
DB_URL=jdbc:mysql://localhost:3306/travel_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ============================================
# JPA Configuration
# ============================================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# ============================================
# Security Configuration
# ============================================
# JWT Configuration
# Feature flag for gradual rollout (default: false for backward compatibility)
# Set to true to enable JWT authentication, false to use session-based authentication
JWT_ENABLED=false

# Generate a strong secret key for production (minimum 256 bits / 32 characters for HS256)
# You can use: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits_32_characters_for_hs256_algorithm
JWT_ACCESS_TOKEN_TTL=900000
JWT_REFRESH_TOKEN_TTL=604800000
JWT_ISSUER=com.aptms.auth
JWT_AUDIENCE=com.aptms.api
JWT_ALGORITHM=HS256

# Legacy JWT expiration (deprecated, use JWT_ACCESS_TOKEN_TTL instead)
JWT_EXPIRATION=900000

# Account Lockout Configuration
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# Password Configuration
# ============================================
PASSWORD_STRENGTH=10
PASSWORD_MIN_LENGTH=8

# ============================================
# Pagination Configuration
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
SPRING_WEB_LOG_LEVEL=DEBUG
HIBERNATE_SQL_LOG_LEVEL=DEBUG
HIBERNATE_BINDER_LOG_LEVEL=TRACE

# ============================================
# Active Profile
# ============================================
# Options: dev, prod, test
SPRING_PROFILES_ACTIVE=dev
