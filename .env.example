# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# ============================================
# Application Configuration
# ============================================
APP_BASE_URL=http://localhost:8080
SERVER_PORT=8080

# ============================================
# Database Configuration
# ============================================
DB_URL=jdbc:mysql://localhost:3306/travel_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here
DB_DRIVER=com.mysql.cj.jdbc.Driver

# ============================================
# JPA Configuration
# ============================================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# ============================================
# Security Configuration
# ============================================
# Generate a strong secret key for production
# You can use: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits
JWT_EXPIRATION=86400000
JWT_ISSUER=APTMS

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ============================================
# Password Configuration
# ============================================
PASSWORD_STRENGTH=10
PASSWORD_MIN_LENGTH=8

# ============================================
# Pagination Configuration
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
APP_LOG_LEVEL=DEBUG
SPRING_WEB_LOG_LEVEL=DEBUG
HIBERNATE_SQL_LOG_LEVEL=DEBUG
HIBERNATE_BINDER_LOG_LEVEL=TRACE

# ============================================
# Active Profile
# ============================================
# Options: dev, prod, test
SPRING_PROFILES_ACTIVE=dev
